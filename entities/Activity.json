{
  "name": "Activity",
  "type": "object",
  "properties": {
    "category": {
      "type": "string",
      "enum": [
        "travel",
        "food",
        "electricity"
      ],
      "description": "Activity category"
    },
    "activity_type": {
      "type": "string",
      "description": "Specific activity type (e.g., car, bus, beef_meal, lighting)"
    },
    "value": {
      "type": "number",
      "description": "Numeric value (km, servings, kWh)"
    },
    "unit": {
      "type": "string",
      "description": "Unit of measurement"
    },
    "carbon_kg": {
      "type": "number",
      "description": "Calculated carbon emissions in kg CO2"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date of the activity"
    },
    "notes": {
      "type": "string",
      "description": "Optional notes"
    }
  },
  "required": [
    "category",
    "activity_type",
    "value",
    "carbon_kg",
    "date"
  ]
}